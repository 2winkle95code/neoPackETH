{
  "name": "neopacketh",
  "version": "1.0.0",
  "description": "A modern Electron UI for packETH — the ethernet packet generator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "packeth",
    "packet",
    "ethernet",
    "network",
    "generator"
  ],
  "author": "2winkle",
  "license": "GPL-3.0",
