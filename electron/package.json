    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.2winkle.neopacketh",
    "productName": "neoPackETH",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  }
